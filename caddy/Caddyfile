    reverse_proxy @health app-staging:3000 {
        health_path /health
        health_interval 10s
        health_timeout 2s
        health_unhealthy_threshold 3
        health_healthy_threshold 2
    }

    reverse_proxy app-staging:3000 {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
        max_fails 3
        fail_timeout 10s
    }
}

